# OpenRouter API Key - get at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# APIFY API Token - get at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Model (free models on OpenRouter)
# Options: nousresearch/hermes-3-llama-3.1-8b:free
#          mistralai/mistral-7b-instruct:free
#          meta-llama/llama-3.1-8b-instruct:free
MODEL=nousresearch/hermes-3-llama-3.1-8b:free

# SEC EDGAR User-Agent (required by SEC - use your real contact info)
SEC_USER_AGENT=YourName your@email.com

# Chatbot port
PORT=7860
